# SEC-02 — Banka 2 dev environment variables.
#
# Kopiraj ovaj fajl u `.env` u istom folderu (Banka-2-Backend/) i edituj
# vrednosti pre `docker compose up`. `.env` JE u .gitignore-u — ne commit-uj
# secret-e ni u dev grane.
#
# `docker compose` ucitava `.env` automatski iz radnog foldera (CWD pri
# `docker compose up`). Ako vrednost ne moze da se nadje, varijable
# oznacene `${X:?...}` u docker-compose.yml-u fail-uju startup sa jasnom
# porukom — ovo je BUDZET PRINCIP: nikad nemamo silent fall-back-ove na
# slabe lozinke u produkciji.
#
# Production: rotiraj sve vrednosti, postavi kroz CI/CD secret manager,
# *NIKAD* ne commit-uj `.env` fajl.

# ── Databases (SEC-02) ───────────────────────────────────────────────────
POSTGRES_PASSWORD=banka2pass_dev_ONLY
POSTGRES_TRADING_PASSWORD=tradingpass_dev_ONLY
# Opcioni — replicator postgres user (default je u docker-compose.yml).
POSTGRES_REPLICATION_PASSWORD=replicator_pass

# ── JWT (auth) ───────────────────────────────────────────────────────────
# HS256 secret. Produkcija MORA biti random >= 256 bita (cca 64 hex).
# N4: banka-core i trading-service FAIL-FAST-uju bez ovog env-a (nema vise
# hardkodovanog default-a u application.properties). MORA biti ISTI string za
# oba servisa — tokeni izdati od banka-core verifikuju se na trading-service-u.
JWT_SECRET=dev-only-jwt-secret-do-not-use-in-prod-rotate-via-env-var-on-each-deploy

# ── Eksterni API kljucevi ────────────────────────────────────────────────
EXCHANGE_API_KEY=
# Alpha Vantage round-robin (4 kljuca, comma-separated).
STOCK_API_KEYS=

# ── Email (SMTP) ─────────────────────────────────────────────────────────
MAIL_USERNAME=banka2.notifications@gmail.com
MAIL_PASSWORD=

# ── Inter-bank protokol (Tim 1 partner banka) ────────────────────────────
# Generisi `head -c 32 /dev/urandom | xxd -p` (64-hex random) za produkciju.
INTERNAL_API_KEY=dev-internal-key
# R2 1396 config-drift fix: ovi dev-default-i MORAJU da se poklope sa app/compose
# default-ima (application.properties:195/198, docker-compose.yml) jer su bilateralno
# dogovoreni sa Tim 1 — inace ko kopira .env.example dobija druge tokene → handshake 401.
PARTNER1_INBOUND_TOKEN=dev-outbound-banka1-to-banka2
PARTNER1_OUTBOUND_TOKEN=dev-inbound-banka2-to-banka1

# ── Inter-bank protokol (Banka 3 partner banka, routing 333) ─────────────
# PARTNER3_INBOUND_TOKEN  = NAS kljuc (izdajemo ga Banci 3; oni ga salju kad zovu nas)
#   — MORA biti jedinstven (NE isti kao PARTNER2_INBOUND_TOKEN / EXBanka 2).
# PARTNER3_OUTBOUND_TOKEN = NJIHOV kljuc (mi ga saljemo kad zovemo njih) — Banka 3 ga dodeljuje.
# Prave vrednosti drzi u .env (gitignored), NE ovde. Base64 token sa +/= drzati pod navodnicima.
PARTNER3_BASE_URL=https://banka.raf-project.com
PARTNER3_ROUTING=333
PARTNER3_INBOUND_TOKEN=dev-banka3-to-banka2
PARTNER3_OUTBOUND_TOKEN=dev-banka2-to-banka3

# ── InfluxDB (opciono — observability/timeseries) ────────────────────────
INFLUX_ADMIN_USER=admin
INFLUX_ADMIN_PASSWORD=admin12345
INFLUX_ORG=banka2
INFLUX_BUCKET=tick-listings
INFLUX_TOKEN=dev-token-change-me-32-bytes-minimum

# ── Spark analytics (read-only user nad trading_db) ──────────────────────
# Koristi se od strane PySpark/MLlib jobs-ova za read-only pristup analytics
# tabelama (analytics_daily, price_predictions) + ostalim trading tabelama.
# Init script (trading-db-init/01-analytics-reader.sh) kreira user-a SAMO
# pri prvom boot-u trading_db kontejnera. Produkcija: rotirati i drzati kroz
# CI/CD secret manager.
ANALYTICS_READER_PASSWORD=analytics_reader_dev_pass_change_me_32_chars_min

# ── Host port overrides (opciono — za Windows Hyper-V exclusion ranges) ──
# BACKEND_HOST_PORT=8081
# GATEWAY_HOST_PORT=8080
# ADMINER_HOST_PORT=9001
# RABBITMQ_HOST_PORT=5672
# RABBITMQ_MGMT_HOST_PORT=15672
