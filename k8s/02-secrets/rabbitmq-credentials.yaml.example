# =========================================================================
# RabbitMQ default user kredencijali. Default `guest/guest` ne radi van
# localhost-a po default-u, ali za demo/dev je proslo. Premestaj u Secret
# tako da i banka-core, trading-service, notification-service citaju iz
# istog Secret-a (sva 3 servisa su konzumenti/produceri RabbitMQ-a).
#
# Kreiraj sa:
#   kubectl create secret generic rabbitmq-credentials \
#     --from-literal=RABBITMQ_DEFAULT_USER="banka2" \
#     --from-literal=RABBITMQ_DEFAULT_PASS="$(openssl rand -hex 16)" \
#     -n banka2-tim2
#
# Verify: kubectl get secret rabbitmq-credentials -n banka2-tim2 -o yaml
# Management UI: kubectl port-forward -n banka2-tim2 svc/rabbitmq-svc 15672:15672
#                → http://localhost:15672 (login sa user/pass iz Secret-a)
# =========================================================================
apiVersion: v1
kind: Secret
metadata:
  name: rabbitmq-credentials
  namespace: banka2-tim2
type: Opaque
stringData:
  RABBITMQ_DEFAULT_USER: "banka2"
  RABBITMQ_DEFAULT_PASS: "REPLACE_ME_WITH_OPENSSL_RAND_HEX_16"
