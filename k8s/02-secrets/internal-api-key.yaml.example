# =========================================================================
# Internal API key za service-to-service /internal/** komunikaciju
# (banka-core ↔ trading-service preko X-Internal-Key header-a).
# MORA biti identicna vrednost u sva 3 servisa (BE, trading, notification).
# Kreiraj sa:
#   kubectl create secret generic internal-api-key \
#     --from-literal=INTERNAL_API_KEY="$(openssl rand -hex 32)" \
#     -n banka2-tim2
# =========================================================================
apiVersion: v1
kind: Secret
metadata:
  name: internal-api-key
  namespace: banka2-tim2
type: Opaque
stringData:
  INTERNAL_API_KEY: "REPLACE_ME_WITH_OPENSSL_RAND_HEX_32"
