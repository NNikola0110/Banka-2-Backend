# =========================================================================
# Gmail SMTP app password za notification-service.
# MAIL_USERNAME je u ConfigMap (banka2.notifications@gmail.com — public).
# MAIL_PASSWORD MORA biti Gmail "App password" (ne regular pwd) jer Gmail
# ne dozvoljava plain pwd-ove za SMTP od 2022.
# Generisanje: https://myaccount.google.com/apppasswords (zahteva 2FA).
# Kreiraj sa:
#   kubectl create secret generic mail-credentials \
#     --from-literal=MAIL_PASSWORD="xxxx xxxx xxxx xxxx" \
#     -n banka2-tim2
# =========================================================================
apiVersion: v1
kind: Secret
metadata:
  name: mail-credentials
  namespace: banka2-tim2
type: Opaque
stringData:
  MAIL_PASSWORD: "REPLACE_ME_GMAIL_APP_PASSWORD"
