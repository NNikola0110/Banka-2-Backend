# =========================================================================
# Grafana admin kredencijali. Default `admin/admin` je security risk
# (svako sa pristupom port-u 3000 postaje admin). Premestaj u K8s Secret.
#
# Kreiraj sa:
#   kubectl create secret generic grafana-credentials \
#     --from-literal=GF_SECURITY_ADMIN_USER="admin" \
#     --from-literal=GF_SECURITY_ADMIN_PASSWORD="$(openssl rand -hex 16)" \
#     -n banka2-tim2
#
# Verify: kubectl get secret grafana-credentials -n banka2-tim2 -o yaml
# Login: kubectl port-forward -n banka2-tim2 svc/grafana-svc 3000:3000 → http://localhost:3000
# =========================================================================
apiVersion: v1
kind: Secret
metadata:
  name: grafana-credentials
  namespace: banka2-tim2
type: Opaque
stringData:
  GF_SECURITY_ADMIN_USER: "admin"
  GF_SECURITY_ADMIN_PASSWORD: "REPLACE_ME_WITH_OPENSSL_RAND_HEX_16"
