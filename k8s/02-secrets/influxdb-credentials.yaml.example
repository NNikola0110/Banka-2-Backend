# =========================================================================
# InfluxDB 2.x bootstrap kredencijali + admin token.
# INFLUX_TOKEN MORA biti min 32 byte-a (zahtevano za init).
# INFLUX_ADMIN_PASSWORD za UI login (port 8086, /signin).
# Kreiraj sa:
#   kubectl create secret generic influxdb-credentials \
#     --from-literal=INFLUX_TOKEN="$(openssl rand -hex 32)" \
#     --from-literal=INFLUX_ADMIN_PASSWORD="$(openssl rand -hex 16)" \
#     -n banka2-tim2
# =========================================================================
apiVersion: v1
kind: Secret
metadata:
  name: influxdb-credentials
  namespace: banka2-tim2
type: Opaque
stringData:
  INFLUX_TOKEN: "REPLACE_ME_WITH_OPENSSL_RAND_HEX_32_MIN_32_BYTES"
  INFLUX_ADMIN_PASSWORD: "REPLACE_ME_WITH_OPENSSL_RAND_HEX_16"
