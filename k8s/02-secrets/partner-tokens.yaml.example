# =========================================================================
# Inter-bank X-Api-Key tokeni za Tim 1 (Banka 1) handshake.
# PARTNER1_INBOUND_TOKEN — Tim 1 salje nama (we verify).
# PARTNER1_OUTBOUND_TOKEN — mi saljemo Tim 1 (Tim 1 verify).
# Razmena tokena se radi pre cross-bank E2E vezbe (manual coord sa Tim 1).
# Kreiraj sa:
#   kubectl create secret generic partner-tokens \
#     --from-literal=PARTNER1_INBOUND_TOKEN="$(openssl rand -hex 32)" \
#     --from-literal=PARTNER1_OUTBOUND_TOKEN="$(openssl rand -hex 32)" \
#     -n banka2-tim2
# =========================================================================
apiVersion: v1
kind: Secret
metadata:
  name: partner-tokens
  namespace: banka2-tim2
type: Opaque
stringData:
  PARTNER1_INBOUND_TOKEN: "REPLACE_ME_WITH_OPENSSL_RAND_HEX_32"
  PARTNER1_OUTBOUND_TOKEN: "REPLACE_ME_WITH_OPENSSL_RAND_HEX_32"
